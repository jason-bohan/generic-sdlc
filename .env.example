# Project Tracker (Agility/VersionOne)
AGILITY_BASE_URL=https://your-instance.v1host.com/YourCompany
AGILITY_API_KEY=your-api-key-here

# Code Review / CI (Azure DevOps)
# Generate at: https://dev.azure.com/_usersSettings/tokens
# Scopes: Code (Read & Write), Build (Read & Execute)
AZURE_DEVOPS_PAT=your-pat-here
AZURE_DEVOPS_EXT_PAT=your-ext-pat-here

# LLM Provider (OpenRouter — optional, for cloud model routing)
OPENROUTER_API_KEY=your-openrouter-key-here

# Target codebase for container agents (docker-compose.override.yml)
# Set to the absolute path of the repo you want agents to work on.
# Leave unset if running without an external workspace.
# WORKSPACE_PATH=/home/yourname/repos/myproject

# MLX (local Apple Silicon inference — alternative to Ollama)
# MLX_HOST=http://localhost:8082
# Larger local model for the brain roles (orchestrator/reviewer); workers stay on the 14B.
# The base URL is unchanged — one MLX server serves both models, only the model id differs.
# MLX_MODEL_32B=mlx-community/Qwen2.5-Coder-32B-Instruct-4bit
# Or override the local brain model directly (takes precedence over MLX_MODEL_32B):
# BRAIN_MODEL_LOCAL=mlx-community/Qwen2.5-Coder-32B-Instruct-4bit

# Linear integration
# API key for the Linear project tracker provider
LINEAR_API_KEY=your-linear-api-key-here
# Team ID to create issues in (find under Settings → API)
LINEAR_TEAM_ID=your-linear-team-id-here
# Webhook signing secret (Linear → Settings → API → Webhooks → signing secret)
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret-here

# GitHub integration (for webhook → Linear sync)
# Webhook secret (GitHub repo → Settings → Webhooks → secret)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here

# Runtime (set automatically by bin/docker-up.ps1 — override if needed)
# SDLC_API_PORT=3001
# SDLC_EXTERNAL_MODE=live   # set to "mock" for demos without live integrations
