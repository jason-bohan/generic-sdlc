# Project Tracker (Agility/VersionOne)
AGILITY_BASE_URL=https://your-instance.v1host.com/YourCompany
AGILITY_API_KEY=your-api-key-here

# Code Review / CI (Azure DevOps)
# Generate at: https://dev.azure.com/_usersSettings/tokens
# Scopes: Code (Read & Write), Build (Read & Execute)
AZURE_DEVOPS_PAT=your-pat-here
AZURE_DEVOPS_EXT_PAT=your-ext-pat-here

# LLM Provider (OpenRouter — optional, for cloud model routing)
OPENROUTER_API_KEY=your-openrouter-key-here

# Runtime (set automatically by bin/docker-up.ps1 — override if needed)
# SDLC_API_PORT=3001
# SDLC_EXTERNAL_MODE=live   # set to "mock" for demos without live integrations
