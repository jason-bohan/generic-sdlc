# Microsoft Bot Framework credentials
# Get these from Azure Portal -> Bot Channels Registration
MicrosoftAppId=YOUR_APP_ID_HERE
MicrosoftAppPassword=YOUR_APP_PASSWORD_HERE

# Your Meitheal mesh router (OpenAI-compatible endpoint)
MESH_API=http://localhost:9337/v1

# Model to use for task extraction (lightweight is fine)
EXTRACTION_MODEL=qwen3:8b

# Python bridge that feeds tasks into fix-pipeline
BRIDGE_URL=http://localhost:9338

# Bot listening port
PORT=3978

# Confidence threshold: only act on extractions above this
CONFIDENCE_THRESHOLD=0.65

# Max meeting memory window (messages)
MEMORY_WINDOW=20
