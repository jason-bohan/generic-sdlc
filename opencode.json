{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:8b": { "name": "Qwen 3 8B" },
        "qwen2.5-coder:14b": { "name": "Qwen 2.5 Coder 14B" },
        "sdlc-local:latest": { "name": "SDLC Local" },
        "nomic-embed-text:latest": { "name": "Nomic Embed Text" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "deepseek/deepseek-v4-flash": { "name": "DeepSeek V4 Flash" }
      }
    },
    "mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX (local)",
      "options": {
        "baseURL": "http://localhost:8084/v1"
      },
      "models": {
        "mlx-community/Qwen2.5-Coder-14B-Instruct-4bit": { "name": "Qwen 2.5 Coder 14B Q4" },
        "mlx-community/Qwen2.5-Coder-14B-Instruct-8bit": { "name": "Qwen 2.5 Coder 14B Q8" },
        "mlx-community/Qwen2.5-Coder-32B-Instruct-4bit": { "name": "Qwen 2.5 Coder 32B Q4" },
        "prism-ml/Bonsai-8B-mlx-1bit": { "name": "Bonsai 8B 1-bit" }
      }
    }
  },
  "model": "mlx/mlx-community/Qwen2.5-Coder-14B-Instruct-4bit",
  "small_model": "ollama/qwen3:8b",
  "agent": {
    "reviewer": {
      "description": "Read-only PR reviewer: may read files and run git/gh to inspect a diff, but MUST NOT modify the repo. Write/edit/patch tools are disabled so it cannot implement instead of review.",
      "tools": { "write": false, "edit": false, "patch": false }
    }
  }
}
