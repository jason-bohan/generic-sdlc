# MeshLLM CUDA runtime image for serving local models.
# The upstream Dockerfile.client is API/client-only; this image uses the
# published Linux CUDA release bundle so `mesh-llm serve --model/--gguf` can
# load the embedded llama.cpp runtime.

# ubuntu24.04 (not 22.04): the mesh-llm v0.71.0 binary requires GLIBC_2.39, which
# 22.04 (glibc 2.35) does not provide — it builds fine but fails at launch with
# "version `GLIBC_2.39' not found". 24.04 ships glibc 2.39 and the same CUDA 13
# runtime libs (libcudart.so.13 / libcublas.so.13) the binary links against.
FROM nvidia/cuda:13.3.0-runtime-ubuntu24.04

# As of v0.66 upstream splits the CUDA bundle into -cuda-12 / -cuda-13 variants;
# match the cuda-13 variant to the nvidia/cuda:13.x base image above.
ARG MESHLLM_VERSION=v0.71.0
ARG MESHLLM_ARCH=x86_64-unknown-linux-gnu-cuda-13

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    libdbus-1-3 \
    libgomp1 \
    libssl3t64 \
    && rm -rf /var/lib/apt/lists/*

# As of v0.66+ the bundle ships a single self-contained mesh-llm binary; the
# standalone rpc-server-cuda / llama-server-cuda binaries (and the *-cuda glob)
# are gone — their functionality is folded into `mesh-llm` subcommands. So we
# install whatever binaries the bundle ships as 0755 rather than naming specific
# ones, then assert the mesh-llm entrypoint actually landed. A future bundle
# restructure that drops mesh-llm fails the `test -x` instead of building a
# broken image.
RUN set -eux; \
    curl -L "https://github.com/Mesh-LLM/mesh-llm/releases/download/${MESHLLM_VERSION}/mesh-llm-${MESHLLM_ARCH}.tar.gz" \
      -o /tmp/mesh-llm.tar.gz; \
    mkdir -p /tmp/mesh-llm /opt/mesh-llm; \
    tar -xzf /tmp/mesh-llm.tar.gz -C /tmp/mesh-llm; \
    find /tmp/mesh-llm -type f -maxdepth 3 -print; \
    cp -R /tmp/mesh-llm/* /opt/mesh-llm/; \
    find /opt/mesh-llm -type f -maxdepth 3 -exec install -m 0755 {} /usr/local/bin/ \;; \
    test -x /usr/local/bin/mesh-llm; \
    rm -rf /tmp/mesh-llm /tmp/mesh-llm.tar.gz

# GPU-free runtime guard. The build never executes mesh-llm, so a binary that
# needs a newer glibc than the base image builds clean but dies at launch with
# "version `GLIBC_x.y' not found" (exactly what v0.71.0 + ubuntu22.04 did). ldd
# resolves the binary against the image's libs and surfaces that mismatch without
# a GPU. libcuda.so.1 (the driver, injected at runtime) shows as "not found" — a
# different message — so it does not false-trip this check.
RUN if ldd /usr/local/bin/mesh-llm 2>&1 | grep -q 'GLIBC_.*not found'; then \
      echo 'ERROR: base image glibc too old for mesh-llm:'; \
      ldd /usr/local/bin/mesh-llm; \
      exit 1; \
    fi

EXPOSE 3131 9337
ENTRYPOINT ["mesh-llm"]
