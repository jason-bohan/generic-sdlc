{
    "name": "sdlc-framework",
    "version": "2.0.0-alpha.0",
    "private": true,
    "description": "SDLC Framework — Multi-agent cooperative workgroup for Cursor",
    "scripts": {
        "server": "tsx --watch src/server/index.ts",
        "setup": "node scripts/setup.cjs",
        "dashboard": "vite --config vite.config.ts",
        "dashboard:build": "vite build --config vite.config.ts",
        "dev": "concurrently -k -n api,dash \"npm run server\" \"node scripts/wait-dev-api.cjs && npm run dashboard\"",
        "tauri": "tauri",
        "tauri:dev": "tauri dev",
        "tauri:build": "tauri build",
        "btw": "tsx scripts/btw.ts",
        "ollama": "tsx scripts/ollama-delegate.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "reset:agents": "powershell -NoProfile -ExecutionPolicy Bypass -File ./bin/reset-agents.ps1",
        "cypress:run": "cypress run",
        "cypress:open": "cypress open",
        "cypress:YourProject": "tsx scripts/cypress-runner.ts",
        "docker:up": "powershell -NoProfile -ExecutionPolicy Bypass -File ./bin/docker-up.ps1",
        "docker:down": "powershell -NoProfile -ExecutionPolicy Bypass -File ./bin/docker-down.ps1",
        "docker:test": "powershell -NoProfile -ExecutionPolicy Bypass -File ./bin/docker-test.ps1",
        "docker:test:unit": "powershell -NoProfile -ExecutionPolicy Bypass -File ./bin/docker-test.ps1 -UnitOnly",
        "docker:test:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File ./bin/docker-test.ps1 -CypressOnly",
        "notify:spy": "tsx scripts/teams-webhook-spy.ts",
        "pr:watch": "tsx scripts/pr-watcher.ts",
        "plan": "tsx scripts/plan-generator.ts",
        "tui": "tsx src/tui/index.tsx",
        "sdlc-framework": "tsx src/tui/index.tsx",
        "db": "harlequin .sdlc-framework/sdlc-framework.db",
        "preinstall": "node -e \"var v=process.versions.node.split('.')[0];if(v>=24){console.error('\\x1b[31mERROR: Node v'+process.versions.node+' detected. SDLC Framework requires Node 22.x. Switch with: nvs use 22\\x1b[0m');process.exit(1)}\"",
        "postinstall": "node -e \"['tools/mcp-agility','tools/mcp-sdlc-framework'].forEach(d=>{try{require('fs').statSync(d+'/package.json');require('child_process').execSync('npm install --production',{cwd:d,stdio:'inherit'})}catch(e){}})\""
    },
    "dependencies": {
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.6.1",
        "@scalar/express-api-reference": "^0.9.14",
        "@tanstack/react-router": "^1.170.4",
        "@tauri-apps/api": "^2.11.0",
        "@tauri-apps/plugin-notification": "^2.3.3",
        "@types/better-sqlite3": "^7.6.13",
        "better-sqlite3": "^12.9.0",
        "chalk": "^5.3.0",
        "chokidar": "^5.0.0",
        "commander": "^14.0.3",
        "dotenv": "^17.4.2",
        "ink": "^7.0.2",
        "ink-link": "^5.0.0",
        "ink-select-input": "^6.2.0",
        "ink-spinner": "^5.0.0",
        "ink-text-input": "^6.0.0",
        "luxon": "^3.5.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "three": "^0.184.0"
    },
    "engines": {
        "node": ">=22.0.0 <25.0.0"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.10.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/luxon": "^3.4.0",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.184.0",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "cypress": "^15.14.2",
        "jsdom": "^29.1.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vitest": "^4.1.5",
        "yaml": "^2.8.4"
    }
}
