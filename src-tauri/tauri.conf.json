{
    "productName": "SDLC Framework - OSV Agents",
    "version": "0.1.0",
    "identifier": "com.osv.sdlc-framework",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:3847",
        "beforeDevCommand": "npm run dashboard",
        "beforeBuildCommand": "npm run dashboard:build"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "SDLC Framework — OSV Agent Workspace",
                "width": 1280,
                "height": 800,
                "minWidth": 900,
                "minHeight": 600,
                "resizable": true,
                "decorations": true,
                "transparent": false
            }
        ],
        "trayIcon": {
            "iconPath": "icons/icon.png",
            "iconAsTemplate": false,
            "tooltip": "SDLC Framework Agents"
        },
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
