  "project": {
    "organization": "your-azure-devops-org",
    "azureProject": "YourProject",
    "repositoryId": "YourRepo",
    "scope": "Your Team",
    "parent": "General",
    "parentOid": "Theme:000000",
    "category": "Roadmap Features",
    "team": "Your Team",
    "owners": ["Your Name"],
    "ownersLastFirst": ["Last, First"],
    "prUrlBase": "https://your-org.visualstudio.com/YourProject/_git/YourRepo/pullrequest"
  },
  "scheduler": {
    "mode": "notify",
    "driver": "generic",
    "loopProvider": {
      "baseUrl": "http://localhost:11434/v1",
      "model": "qwen3:14b",
      "apiKey": "",
      "maxTokens": 4096,
      "temperature": 0.2
    },
    "genericDriver": {
      "command": "my-agent-cli",
      "args": ["-p", "{promptFile}", "--workspace", "{workspaceDir}", "--model", "{model}"]
    },
    "agents": {
      "frontend": {
        "enabled": true,
        "autoStart": false,
        "stepMode": false,
        "stepModePhases": ["analyzing", "generating-code", "validating", "creating-pr", "watching-reviews", "addressing-feedback", "running-cypress"],
        "adoPat": ""
      },
      "backend": { "enabled": false, "autoStart": false, "stepMode": false },
      "qa": { "enabled": false, "autoStart": false, "stepMode": false },
      "ux": { "enabled": false, "autoStart": false, "stepMode": false },
      "reviewer": {
        "enabled": true,
        "autoStart": false,
        "stepMode": false,
        "role": "reviewer",
        "watchesTeamsChannel": "Agent Activity",
        "adoPat": ""
      },
      "devops": {
        "enabled": true,
        "autoStart": false,
        "stepMode": false,
        "role": "devops",
        "watchesPipeline": true,
        "adoPat": ""
      }
    }
  },
  "notifications": {
    "teams": {
      "webhookUrl": "",
      "channels": {
        "agentActivity": "Agent Activity",
        "prReviews": "PR Reviews"
      },
      "notifyOn": ["creating-pr", "complete", "error", "pending-approval"]
    }
  }
}
