#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in
    /*) SOURCE="$TARGET" ;;
    *) SOURCE="$DIR/$TARGET" ;;
  esac
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"
TSX="$ROOT_DIR/node_modules/.bin/tsx"

if [ ! -x "$TSX" ]; then
  echo "tsx not found at $TSX. Run setup in $ROOT_DIR first." >&2
  exit 1
fi

if [ "$#" -eq 0 ] || [ "${1:-}" = "--tui" ]; then
  if [ "${1:-}" = "--tui" ]; then shift; fi
  exec "$TSX" "$ROOT_DIR/src/tui/index.tsx" chatllm "$@"
fi

exec "$TSX" "$ROOT_DIR/scripts/chatllm.ts" "$@"
