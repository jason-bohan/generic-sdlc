#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find repo root
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in /*) SOURCE="$TARGET" ;; *) SOURCE="$DIR/$TARGET" ;; esac
done
REPO_ROOT="$(cd -P "$(dirname "$SOURCE")/.." >/dev/null 2>&1 && pwd)"

# Load .env for MLX config
if [ -f "$REPO_ROOT/.env" ]; then
    set -a; source "$REPO_ROOT/.env"; set +a
fi

MLX_BASE="${MLX_HOST_14B:-${MLX_HOST:-http://localhost:8083}}"
MLX_BASE="${MLX_BASE%/v1}"
MODEL="${MLX_MODEL_14B:-${MLX_MODEL:-mlx-community/Qwen2.5-Coder-14B-Instruct-4bit}}"

AIDER="$(command -v aider 2>/dev/null || true)"
if [ -z "$AIDER" ]; then
    echo "aider not found. Install with: pipx install aider-chat" >&2
    exit 1
fi

echo "  aicode  →  $MODEL  @  $MLX_BASE" >&2
echo "" >&2

exec "$AIDER" \
    --model "openai/${MODEL}" \
    --openai-api-base "${MLX_BASE}/v1" \
    --openai-api-key fake \
    --no-show-model-warnings \
    --no-check-update \
    "$@"
